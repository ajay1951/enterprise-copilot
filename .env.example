# OpenRouter / LLM Configuration
OPENAI_API_KEY=sk-or-v1-your-openrouter-api-key-here
USE_OPENROUTER=true
LLM_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# Relational Database (PostgreSQL)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://admin:securepassword@localhost:5432/copilot

# Vector Database (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_cloud_api_key_if_using_cloud

# Security & CORS
JWT_SECRET_KEY=generate_a_strong_random_secret_key_here
ALLOWED_ORIGINS=http://localhost:3000,https://your-production-frontend.com

# Admin Seeding
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change_this_before_deploying
